{
  "name": "bottle-recycler",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": "https://rangerchris.github.io/BottleRecycler",
  "scripts": {
    "dev": "vite",
    "dev:coverage": "vite --mode coverage",
    "build": "tsc -b && vite build && tsc --project tsconfig.json --outDir dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npx playwright test --ui",
    "test:e2e": "npx playwright test",
    "test:coverage": "npx playwright test",
    "run-tests-and-merge": "npx playwright test && node scripts/merge-coverage.js",
    "coverage": "start-server-and-test \"npm run dev:coverage\" http://localhost:5173 \"npm run run-tests-and-merge\"",
    "show-coverage": "npx playwright show-report coverage/report",
    "vitest:coverage": "vitest run --coverage",
    "vitest:coverage:open": "start .\\coverage\\vitest\\index.html",
    "start": "node dist/server.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/testing-library__react": "^10.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "start-server-and-test": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
