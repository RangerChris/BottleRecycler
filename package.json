{
  "name": "bottle-recycler",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": "https://rangerchris.github.io/BottleRecycler",
  "scripts": {
    "dev": "vite",
    "dev:coverage": "vite --mode coverage",
    "build": "tsc -b && vite build && tsc server.ts --outDir dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npx playwright test --ui",
    "test:e2e": "npx playwright test",
    "test:coverage": "npx playwright test",
    "run-tests-and-merge": "npx playwright test && node scripts/merge-coverage.js",
    "coverage": "start-server-and-test \"npm run dev:coverage\" http://localhost:5173 \"npm run run-tests-and-merge\"",
    "show-coverage": "npx playwright show-report coverage/report",
    "vitest:coverage": "vitest run --coverage",
    "vitest:coverage:open": "start .\\coverage\\vitest\\index.html",
    "start": "node dist/server.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/testing-library__react": "^10.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^28.1.0",
    "nyc": "^18.0.0",
    "react": "^19.2.4",
    "start-server-and-test": "^2.1.5",
    "ts-node": "^10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.1.2"
  }
}
